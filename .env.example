# Anthropic API key — required. Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# Absolute path on the host to mount as /workspace inside the container.
# Example: /home/alice/projects
WORKSPACE_PATH=/path/to/your/projects

# UID/GID for the claude user inside the container.
# Run `id -u` and `id -g` on the host to find your values.
# Defaults to 1000/1000 (first user on most Linux systems).
USER_ID=1000
GROUP_ID=1000
